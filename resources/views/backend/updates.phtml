                        <p>
                            <?=sprintf(trans('Run %s from the command line to update Devflow core.'), '<code>php codex cms:update</code>');?>
                        </p>
                    <?php else : ?>
                        <div class="alert alert-success">
                            <?=sprintf(trans_html('Devflow %s is up to date.'), esc_html($params['updates']['core']['current']));?>
                        </div>
                    <?php endif; ?>
                </div>
            </div>

            <?php $sections = [
                'plugins' => ['title' => 'Plugins', 'single' => '/admin/updates/plugin/', 'all' => '/admin/updates/plugin/all/'],
                'themes' => ['title' => 'Themes', 'single' => '/admin/updates/theme/', 'all' => '/admin/updates/theme/all/'],
            ]; ?>

            <?php foreach ($sections as $key => $section) : ?>
                <div class="box box-default">
                    <div class="box-header with-border">
                        <h3 class="box-title"><?=esc_html($section['title']);?></h3>

                        <?php if (!empty($params['updates'][$key])) : ?>
                            <div class="box-tools pull-right">
                                <form method="post" action="<?=esc_url($section['all']);?>">
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <?=sprintf(trans_html('Update All %s.'), esc_html($section['title']));?>
                                    </button>
                                </form>
                            </div>
                        <?php endif; ?>
                    </div>

                    <div class="box-body table-responsive no-padding">
                        <?php if (empty($params['updates'][$key])) : ?>
                            <div class="p-3" style="padding:15px;">
                                <div class="alert alert-success">
                                    <?=sprintf(
                                        trans_html('No %s updates available.'),
                                        esc_html(Inflector::singularize(strtolower($section['title'])))
                                    );?>
                                </div>
                            </div>
                        <?php else : ?>
                            <table class="table table-hover">
                                <thead>
                                <tr>
                                    <th><?= trans_html(string: 'Package'); ?></th>
                                    <th><?= trans_html(string: 'Current'); ?></th>
                                    <th><?= trans_html(string: 'Latest'); ?></th>
                                    <th class="text-right"><?= trans_html(string: 'Action'); ?></th>
                                </tr>
                                </thead>
                                <tbody>
                                <?php foreach ($params['updates'][$key] as $package) : ?>
                                    <tr>
                                        <td>
                                            <strong><?=esc_html($package['name']);?></strong>
                                            <?php if (!empty($package['description'])) : ?>
                                                <br><small><?=esc_html($package['description']);?></small>
                                            <?php endif; ?>
                                        </td>
                                        <td><?=esc_html($package['current']);?></td>
                                        <td><?=esc_html($package['latest']);?></td>
                                        <td class="text-right">
                                            <form method="post" action="<?=esc_url($section['single']);?>" class="js-update-form">
                                                <input type="hidden" name="package" value="<?=esc_attr($package['name']);?>">
                                                <button type="submit" class="btn btn-success btn-sm">
                                                    <?= trans_html(string: 'Update'); ?>
                                                </button>
                                            </form>
                                        </td>
