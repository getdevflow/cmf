<?php

declare(strict_types=1);

use App\Shared\Services\Registry;
use Qubus\Support\Inflector;

use function App\Shared\Helpers\admin_url;
use function Codefy\Framework\Helpers\trans;
use function Codefy\Framework\Helpers\trans_html;
use function Qubus\Security\Helpers\esc_attr;
use function Qubus\Security\Helpers\esc_html;
use function Qubus\Security\Helpers\esc_url;

$this->parent('framework::backend/layouts/admin-layout');
$this->block('backend', function ($params) {
Registry::getInstance()->{'set'}('screen_parent', 'dashboard');
Registry::getInstance()->{'set'}('screen_child', 'updates');
?>

    <!-- Content Wrapper. Contains page content -->
    <div class="content-wrapper">
        <!-- Content Header (Page header) -->
        <section class="content-header">
            <h1>
                <?= trans_html(string: 'Updates'); ?>
                <small><?= trans_html(string: 'Devflow CMF, plugins, and themes'); ?></small>
            </h1>
            <ol class="breadcrumb">
                <li><a href="<?=admin_url();?>"><i class="fa fa-dashboard"></i> <?= trans_html(string: 'Dashboard'); ?></a></li>
                <li class="active"><?= trans_html(string: 'Updates'); ?></li>
            </ol>
        </section>

        <!-- Main content -->
        <section class="content">

            <div class="box box-primary">
                <div class="box-header with-border">
                    <h3 class="box-title">Devflow CMF</h3>
                </div>
                <div class="box-body">
                    <?php if (!empty($params['updates']['stale'])) : ?>
                        <div class="alert alert-warning">
                            <?=trans_html('Update checks are temporarily unavailable. Showing cached or fallback results.');?>
                        </div>
                    <?php endif; ?>
                    
                    <?php if ($params['updates']['core']['available']) : ?>
                        <div class="alert alert-info">
                            <?=sprintf(trans('Devflow <strong>%s</strong> is available.'), esc_html($params['updates']['core']['latest']));?>
                            <?=sprintf(trans('Current version: <strong>%s</strong>'), esc_html($params['updates']['core']['current']));?>
