    <script>
        (function ($) {

            let pendingRemoveButton = null;

            $(document).on('click', '.btn-extension-action', function () {
                const $button = $(this);
                const action = $button.data('action');

                if (action === 'remove') {
                    pendingRemoveButton = $button;

                    $('#remove-extension-modal').modal('show');

                    return;
                }

                runExtensionAction($button);
            });

            $(document).on('click', '.js-confirm-remove-extension', function () {
                if (! pendingRemoveButton) {
                    return;
                }

                $('#remove-extension-modal').modal('hide');

                runExtensionAction(pendingRemoveButton);

                pendingRemoveButton = null;
            });

            function runExtensionAction($button) {
                const action = $button.data('action');
                const packageName = $button.data('package');
                const type = $button.data('type');

                const isRemove = action === 'remove';

                const url = isRemove
                    ? '<?= admin_url('extension/remove/'); ?>'
                    : '<?= admin_url('extension/install/'); ?>';

                $button.prop('disabled', true).html(
                    isRemove
                        ? '<i class="fa fa-spinner fa-spin"></i> <?= trans_html('Removing...'); ?>'
                        : '<i class="fa fa-spinner fa-spin"></i> <?= trans_html('Installing...'); ?>'
                );

                $.ajax({
                    type: 'POST',
                    url: url,
                    dataType: 'json',
                    data: {
                        package: packageName,
                        type: type
                    }
                }).done(function (response) {

                    $('#installer-alert').html(
                        '<div class="alert alert-success alert-dismissible fade in">' +
                        '<button type="button" class="close" data-dismiss="alert">&times;</button>' +
                        response.message +
                        '</div>'
                    );

                    if (isRemove) {
                        $button
                            .removeClass('btn-danger')
                            .addClass('btn-success')
                            .data('action', 'install')
                            .html('<i class="fa fa-download"></i> <?= trans_html('Install'); ?>');
                    } else {
                        $button
                            .removeClass('btn-success')
                            .addClass('btn-danger')
                            .data('action', 'remove')
                            .html('<i class="fa fa-trash"></i> <?= trans_html('Remove'); ?>');
                    }

                    $button.prop('disabled', false);

                }).fail(function (xhr) {

                    let message = isRemove
                        ? <?= json_encode(trans_html('Remove failed.')); ?>
                        : <?= json_encode(trans_html('Install failed.')); ?>;

                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        message = xhr.responseJSON.message;
                    }

                    $('#installer-alert').html(
                        '<div class="alert alert-danger alert-dismissible fade in">' +
                        '<button type="button" class="close" data-dismiss="alert">&times;</button>' +
                        message +
                        '</div>'
                    );

                    $button.prop('disabled', false).html(
                        isRemove
                            ? '<i class="fa fa-trash"></i> <?= trans_html('Remove'); ?>'
                            : '<i class="fa fa-download"></i> <?= trans_html('Install'); ?>'
                    );
                });
            }

        })(jQuery);
    </script>
    <div class="modal fade" id="remove-extension-modal" tabindex="-1" role="dialog" aria-labelledby="remove-extension-label">
        <div class="modal-dialog modal-sm" role="document">
            <div class="modal-content">

                <div class="modal-header bg-danger">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>

                    <h4 class="modal-title" id="remove-extension-label">
