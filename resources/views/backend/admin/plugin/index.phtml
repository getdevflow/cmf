    <script>
        jQuery(function ($) {
            function showPluginVisibilityAlert(type, message) {
                const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';

                const $alert = $(
                    '<div class="alert ' + alertClass + ' alert-dismissible fade in" role="alert">' +
                    '<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
                    '<span aria-hidden="true">&times;</span>' +
                    '</button>' +
                    message +
                    '</div>'
                );

                $('#plugin-visibility-alert-wrap').html($alert);

                setTimeout(function () {
                    $alert.alert('close');
                }, 3500);
            }

            $('.js-network-plugin-toggle').on('change', function () {
                const $toggle = $(this);
                const isAvailable = $toggle.is(':checked');

                $.ajax({
                    url: "<?= admin_url('plugin/network-toggle/'); ?>",
                    type: 'POST',
                    dataType: 'json',
                    data: {
                        plugin: $toggle.data('plugin'),
                        available: isAvailable ? 1 : 0
                    },
                    success: function (response) {
                        if (! response.success) {
                            $toggle.prop('checked', !isAvailable);

                            showPluginVisibilityAlert(
                                'error',
                                response.message || 'Unable to update plugin visibility.'
                            );

                            return;
                        }

                        if (isAvailable) {
                            showPluginVisibilityAlert(
                                'success',
                                'Plugin is now available on subsites.'
                            );
                        } else {
                            showPluginVisibilityAlert(
                                'success',
                                'Plugin has been removed from subsite plugin lists.'
                            );
                        }
                    },
                    error: function (xhr) {
                        $toggle.prop('checked', !isAvailable);

                        showPluginVisibilityAlert(
                            'error',
                            'Unable to update plugin visibility.'
                        );
                    }
                });
            });
        });
    </script>
